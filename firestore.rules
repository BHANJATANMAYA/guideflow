rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    match /events/{eventId} {
      allow read: if true;
      allow write: if false; 
    }
    match /venues/{venueId} {
      allow read: if true;
      allow write: if false;
      
      match /zones/{zoneId} {
        allow read: if true;
        allow write: if false;
      }
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
